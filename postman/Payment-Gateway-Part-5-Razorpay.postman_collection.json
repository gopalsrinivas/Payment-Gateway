{
  "info": {
    "name": "Payment Gateway Part 5 Razorpay Test Mode",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "token", "value": "paste_customer_jwt_here" },
    { "key": "orderId", "value": "35" },
    { "key": "paymentId", "value": "10" },
    { "key": "razorpayOrderId", "value": "order_test_placeholder" },
    { "key": "razorpayPaymentId", "value": "pay_test_placeholder" },
    { "key": "razorpaySignature", "value": "signature_from_razorpay_checkout" },
    { "key": "webhookSignature", "value": "signature_from_razorpay_dashboard_or_test_script" }
  ],
  "item": [
    {
      "name": "Login Customer",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"customer@example.com\",\n  \"password\": \"Customer@12345\"\n}" }
      }
    },
    {
      "name": "Initialize Razorpay Order",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/payments/initialize",
        "body": { "mode": "raw", "raw": "{\n  \"orderId\": {{orderId}}\n}" }
      }
    },
    {
      "name": "Verify Payment",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/payments/verify",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"paymentId\": {{paymentId}},\n  \"applicationOrderId\": {{orderId}},\n  \"razorpayOrderId\": \"{{razorpayOrderId}}\",\n  \"razorpayPaymentId\": \"{{razorpayPaymentId}}\",\n  \"razorpaySignature\": \"{{razorpaySignature}}\"\n}"
        }
      }
    },
    {
      "name": "Record Payment Failure",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/payments/failure",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"paymentId\": {{paymentId}},\n  \"applicationOrderId\": {{orderId}},\n  \"razorpayOrderId\": \"{{razorpayOrderId}}\",\n  \"errorCode\": \"BAD_REQUEST_ERROR\",\n  \"errorDescription\": \"Payment failed in test mode\",\n  \"errorReason\": \"payment_failed\"\n}"
        }
      }
    },
    {
      "name": "Payment History",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/payments/history"
      }
    },
    {
      "name": "Razorpay Webhook Placeholder",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Razorpay-Signature", "value": "{{webhookSignature}}" }
        ],
        "url": "{{baseUrl}}/webhooks/razorpay",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"evt_test_placeholder\",\n  \"event\": \"payment.captured\",\n  \"payload\": {\n    \"payment\": {\n      \"entity\": {\n        \"id\": \"{{razorpayPaymentId}}\",\n        \"order_id\": \"{{razorpayOrderId}}\",\n        \"amount\": 99900\n      }\n    }\n  }\n}"
        },
        "description": "Signature must be generated by Razorpay or by a local test script using the webhook secret. Do not store real secrets in this collection."
      }
    }
  ]
}
